{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-message", 
    "dialog:default",
    "fs:allow-app-write",
    "fs:allow-app-read",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:scope-appdata",
    {
      "identifier": "fs:scope",
      "allow": [
      "$APPDATA/projects",
      "$APPDATA/projects/*"
    ]
    }
  ]
}
